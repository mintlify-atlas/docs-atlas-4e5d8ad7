  "keyFeatures": [
    "PIN-gated device verification before ad display — forces users through a monetized verification flow",
    "Interstitial ad serving via programmatically drawn Android dialogs (zero external dependencies)",
    "Impression and click tracking per ad and per device",
    "Configurable PIN expiry (never or duration-based) per app",
    "MT Manager / smali injection support for patching third-party APKs",
    "Web-based admin dashboard for managing API keys, ads, PIN configs, and verified devices",
    "DEX packaging for use without Android Studio",
    "Global or per-app PIN unlock modes"
  ],
  "publicApiSurface": [
